# ── VaultStream frontend configuration ──
# Copy to .env.local. Placeholder Supabase values => mock auth mode
# (use the demo accounts on the login page, password: demo1234).

# Backend API (point at your deployed backend in production)
NEXT_PUBLIC_HTTP_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_API_URL=ws://localhost:8000/ws/alerts

# Supabase auth (placeholder => mock mode)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Error tracking (optional)
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn
