# ── VaultStream backend configuration ──
# Copy to .env and fill in. Leave the *_SECRET / supabase values as the
# "your-..." placeholders to run in local mock mode (no external services).

# Supabase (auth + persistence). Placeholder => mock auth (accepts mock-token-<role>).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=your-jwt-secret
SUPABASE_SERVICE_KEY=your-service-key

# Relational database (optional). Unset => mock mode (in-memory). Set =>
# Postgres persistence for alerts, users/roles and the audit trail.
# Local docker-compose: postgresql+psycopg2://vault:vault@localhost:5433/vaultstream
# DATABASE_URL=postgresql+psycopg2://vault:vault@localhost:5433/vaultstream

# Feature store (Redis). Use a local URL for dev, or Upstash REST in production.
LOCAL_REDIS_URL=redis://localhost:6379
UPSTASH_REDIS_REST_URL=https://your-redis-url
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# Streaming (Redpanda / Kafka). If unreachable, the app falls back to standalone mode.
REDPANDA_BROKER=localhost:9092

# Model artifact (bundled in the image by default)
MODEL_PATH=models/fraud_model.pkl

# Error tracking (optional). Placeholder => disabled.
SENTRY_DSN=https://your-sentry-dsn

# Fraud notifications (optional). Slack/Discord-compatible incoming webhook —
# fired when a transaction is scored FRAUD. Placeholder/empty => disabled.
NOTIFY_WEBHOOK_URL=https://your-webhook-url

# CORS — comma-separated allowed origins in production, or "*" for local dev.
# Example: CORS_ORIGINS=https://vaultstream.vercel.app
CORS_ORIGINS=*
